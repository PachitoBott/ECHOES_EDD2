{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ECHOES - Jugar (Menu + Cinematica)",
            "type": "shell",
            "command": "python Main.py",
            "options": {
                "cwd": "${workspaceFolder}/CODIGO"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "ECHOES - Debug (Sin Menu)",
            "type": "shell",
            "command": "python Main.py --skip-menu --debug",
            "options": {
                "cwd": "${workspaceFolder}/CODIGO"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
